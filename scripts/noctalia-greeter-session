#!/usr/bin/env sh
set -eu

GREETER_BIN="${NOCTALIA_GREETER_BIN:-/usr/local/bin/noctalia-greeter}"
LOG_FILE="${NOCTALIA_GREETER_LOG:-/tmp/noctalia-greeter-greetd.log}"

# Tee cage + greeter output to a single file for greetd debugging.
exec >>"${LOG_FILE}" 2>&1

echo "=== noctalia-greeter-session $(date -Iseconds) pid=$$ uid=$(id -u) euid=$(id -u -r 2>/dev/null || id -u) ==="
echo "GREETER_BIN=${GREETER_BIN}"
echo "LOG_FILE=${LOG_FILE}"

# Always use a private runtime dir under greetd. PAM may export
# XDG_RUNTIME_DIR=/run/user/<uid> without keeping that directory around for the
# full cage+greeter lifetime (greeter then fails wl_display_connect with ENOENT).
_pam_runtime="${XDG_RUNTIME_DIR:-unset}"
XDG_RUNTIME_DIR="/tmp/noctalia-runtime-$(id -u)"
export XDG_RUNTIME_DIR
mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"

echo "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR} (pam=${_pam_runtime})"
echo "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}"

unset WAYLAND_DISPLAY
if command -v dbus-run-session >/dev/null 2>&1; then
  echo "launch: dbus-run-session cage -s -- ${GREETER_BIN}"
  exec dbus-run-session -- env XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" cage -s -- "${GREETER_BIN}"
fi

echo "warn: dbus-run-session not found; starting cage without a session bus."
echo "launch: cage -s -- ${GREETER_BIN}"
exec env XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" cage -s -- "${GREETER_BIN}"
